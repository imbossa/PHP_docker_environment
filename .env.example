# Copy this file to .env and fill in real secrets for local/development
# Do not commit actual credentials into version control.

# General
PWD=./
LOCAL_STORAGE_PATH=./
LOCAL_WEB_PATH=/path/to/your/workspace

# Network / container naming
NETWORK_EXT_NAME=my_com
IPV4_PREFIX=172.28.1.
CONTAINER_PREFIX=com_

# Timezone
TIMEZONE=Asia/Shanghai

# PHP / runtime
PHP_VERSION=8.4.4-fpm
NGINX_VERSION=1.27.4

# Service images
REDIS_VERSION=redis:7.4.2
MYSQL_VERSION=mysql:8.4.8
MONGO_VERSION=mongo:7.0.1
RABBITMQ_VERSION=rabbitmq:4.2.5-management

# Databases / caches (replace with secure values in your environment)
MYSQL_ROOT_PASSWORD=<your_mysql_root_password>
REDIS_PASSWORD=<your_redis_password>
MONGO_ROOT_USERNAME=root
MONGO_ROOT_PASSWORD=<your_mongo_password>

# RabbitMQ
RABBITMQ_USERNAME=admin
RABBITMQ_PASSWORD=<your_rabbitmq_password>
RABBITMQ_VHOST=/

# TLS/Certificates (if used not committed) - do not commit actual keys here
# PRIVATE_KEY_PEM path on host/secret store should be mounted at runtime
